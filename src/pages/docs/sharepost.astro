---
import ShareButtons from "@plugdash/sharepost/ShareButtons.astro";
import InstallCommand from "../../components/InstallCommand.astro";
import PluginReference from "../../components/PluginReference.astro";
import { demoPost, pluginDocToc } from "../../data/demoPost";
import { getPlugin } from "../../data/plugins";
import Doc from "../../layouts/Doc.astro";

const plugin = getPlugin("sharepost")!;
---

<Doc
  tocEntries={pluginDocToc}
  currentSlug="sharepost"
  readingTimeMinutes={2}
  wordCount={260}
  title="sharepost"
  section="@plugdash/sharepost"
  description="Social share buttons with no JavaScript libraries."
>
  <h2 id="what-it-does">What it does</h2>
  <p>
    On every publish, generates share URLs for Twitter/X, LinkedIn,
    WhatsApp, Bluesky, and email and writes them to
    <code>post.data.metadata.shareUrls</code>. Ships
    <code>ShareButtons.astro</code> with four variants. No third-party
    JavaScript, no tracking.
  </p>

  <h2 id="install">Install</h2>
  <InstallCommand command={plugin.installCommand} />

  <h2 id="register">Register</h2>
  <pre><code>{`import { sharepostPlugin } from "@plugdash/sharepost"

emdash({
  plugins: [
    sharepostPlugin({ via: "abhinavs" }),
  ],
})`}</code></pre>
  <p>The <code>via</code> option is your Twitter/X handle (without the @).
  It appears in the pre-filled tweet text.</p>

  <h2 id="add-the-component">Add the component</h2>
  <pre><code>{`---
import ShareButtons from "@plugdash/sharepost/ShareButtons.astro"
---
<ShareButtons post={post} />`}</code></pre>

  <h2 id="live-demo">Live demo</h2>
  <div class="demo-inline">
    <ShareButtons post={demoPost} />
  </div>

  <PluginReference plugin={plugin} />

  <h2 id="for-agents">For agents</h2>
  <p>After install, publish a post and verify
  <code>post.data.metadata.shareUrls</code> is an object with one URL per
  configured platform. The share URLs are pre-filled with the post title
  and canonical URL - no browser-side share SDK needed.</p>
</Doc>
