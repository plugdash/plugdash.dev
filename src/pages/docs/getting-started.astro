---
import InstallCommand from "../../components/InstallCommand.astro";
import Doc from "../../layouts/Doc.astro";

const tocEntries = [
  { id: "what-plugdash-is", text: "What plugdash is", level: 2 as const, children: [] },
  { id: "how-emdash-plugins-work", text: "How EmDash plugins work", level: 2 as const, children: [] },
  { id: "install-readtime", text: "Install readtime", level: 2 as const, children: [
    { id: "step-1-install", text: "Step 1: install", level: 3 as const, children: [] },
    { id: "step-2-register", text: "Step 2: register", level: 3 as const, children: [] },
    { id: "step-3-add-the-component", text: "Step 3: add the component", level: 3 as const, children: [] },
  ] },
  { id: "change-the-look", text: "Change the look", level: 2 as const, children: [] },
  { id: "next-steps", text: "Next steps", level: 2 as const, children: [] },
