---
import HeartButton from "@plugdash/heartpost/HeartButton.astro";
import ReadingTime from "@plugdash/readtime/ReadingTime.astro";
import ShareButtons from "@plugdash/sharepost/ShareButtons.astro";
import CopyLink from "@plugdash/shortlink/CopyLink.astro";
import PluginCard from "../components/PluginCard.astro";
import { buildDemoPost } from "../data/demoPost";
import { sortedPlugins } from "../data/plugins";
import Base from "../layouts/Base.astro";

const plugins = sortedPlugins();

// Fixture post with a real message + URL so share buttons share something
// worth sharing. The heart counter reads post.id, so it must be top-level.
const demoPost = buildDemoPost({
  id: "plugdash-home",
  slug: "index",
  title: "PlugDash - drop-in plugins for EmDash",
  url: "https://plugdash.dev",
  message: "PlugDash: drop-in plugins that make EmDash sites feel considered. Reading time, shares, hearts, short links - all working out of the box.",
  heartCount: 4,
});
---

<Base title="PlugDash - drop-in plugins for EmDash">
  <section class="hero container">
    <p class="eyebrow">For writers, bloggers, and teams running EmDash</p>
    <h1 class="hero-headline">
      The plugins your readers<br />notice without knowing why.
    </h1>
    <p class="hero-sub">
      Drop-in plugins that make EmDash sites feel considered.
      Reading time. Social sharing. Hearts. Short links.
      Everything works out of the box.
    </p>
    <div class="hero-cta">
      <a href="/plugins" class="btn btn-primary">Browse plugins</a>
      <a href="https://github.com/plugdash/plugdash" class="btn btn-ghost" rel="noopener">
        github.com/plugdash/plugdash
      </a>
    </div>
  </section>

  <section class="demo-strip container-narrow">
    <div class="demo-row">
      <div class="demo-cell">
        <ReadingTime post={demoPost} variant="inline" />
      </div>
      <div class="demo-cell">
        <ShareButtons post={demoPost} />
      </div>
      <div class="demo-cell">
        <HeartButton post={demoPost} />
      </div>
      <div class="demo-cell">
        <CopyLink post={demoPost} variant="pill" showUrl />
      </div>
    </div>
    <p class="demo-caption">
      This page uses the readtime, sharepost, heartpost, and shortlink plugins
    </p>
  </section>

  <section class="grid-section container">
    <h2 class="grid-heading">Everything a blog expects</h2>
    <div class="plugin-grid">
      {plugins.map((p) => (
        <PluginCard
          name={p.name}
          tagline={p.homeCardCopy}
          status={p.status}
          installCommand={p.installCommand}
          slug={p.slug}
        />
      ))}
    </div>
  </section>

  <section class="built container">
    <header class="built-header">
      <h2 class="grid-heading">Built to be kept</h2>
      <p class="built-lede">Install it. Change it. Prove it on the page you are reading.</p>
    </header>
    <div class="built-grid">
      <article class="built-card">
        <span class="built-num">01</span>
        <h3>Works on install</h3>
        <p>
          Defaults that look considered, not default. Add one import to
          your layout and your readers see the result. No config required
          to ship something good.
        </p>
      </article>
      <article class="built-card">
        <span class="built-num">02</span>
        <h3>Yours to change</h3>
        <p>
          Every visual value is a CSS custom property. Variants for tone,
          sizes for density, tokens that bend to your theme without
          fighting it.
        </p>
      </article>
      <article class="built-card">
        <span class="built-num">03</span>
        <h3>Proven on this page</h3>
        <p>
          This site runs EmDash with every PlugDash plugin installed.
          The reading time, the share buttons, the heart - all running
          live. If it ships here, it ships.
        </p>
      </article>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 1.5rem 2rem;
    text-align: left;
  }
  .hero .eyebrow {
    margin-bottom: 1rem;
  }
  .hero-headline {
    font-size: clamp(2rem, 5.5vw, 3.25rem);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    max-width: 26ch;
  }
  .hero-sub {
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.55;
    max-width: 48rem;
    margin-bottom: 1.75rem;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 6px;
    padding: 0.55rem 0.95rem;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background var(--plugdash-transition), border-color var(--plugdash-transition), color var(--plugdash-transition);
    border: 1px solid transparent;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--accent-fg);
  }
  .btn-primary:hover {
    background: var(--accent-light);
    color: var(--accent-fg);
  }
  .btn-ghost {
    background: var(--surface);
    color: var(--muted);
    border-color: var(--border);
  }
  .btn-ghost:hover {
    background: var(--surface);
    color: var(--text);
    border-color: var(--muted);
  }

  .demo-strip {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin: 2rem auto;
  }
  .demo-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .demo-cell {
    display: inline-flex;
    align-items: center;
    padding: 0 1rem;
    border-right: 1px solid var(--border);
  }
  .demo-cell:first-child { padding-left: 0; }
  .demo-cell:last-child {
    padding-right: 0;
    border-right: none;
  }
  .demo-caption {
    margin-top: 0.75rem;
    color: var(--muted);
    font-size: 0.8rem;
  }

  .grid-section {
    padding: 3rem 1.5rem;
  }
  .grid-heading {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }
  .plugin-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) {
    .plugin-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .built {
    padding: 3rem 1.5rem 5rem;
  }
  .built-header {
    margin-bottom: 2rem;
    max-width: 40rem;
  }
  .built-lede {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.55;
    margin-top: 0.5rem;
  }
  .built-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) {
    .built-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }
  .built-card {
    position: relative;
    padding: 1.5rem 1.25rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }
  .built-num {
    display: inline-block;
    font-family: var(--plugdash-font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }
  .built-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-strong);
  }
  .built-card p {
    color: var(--muted);
    font-size: 0.925rem;
    line-height: 1.6;
    margin: 0;
  }
</style>
