---
import Callout from "@plugdash/callout/Callout.astro";
import EngagementBar from "@plugdash/engage/EngagementBar.astro";
import HeartButton from "@plugdash/heartpost/HeartButton.astro";
import ReadingTime from "@plugdash/readtime/ReadingTime.astro";
import ShareButtons from "@plugdash/sharepost/ShareButtons.astro";
import CopyLink from "@plugdash/shortlink/CopyLink.astro";
import TableOfContents from "@plugdash/tocgen/TableOfContents.astro";
import InstallCommand from "../../components/InstallCommand.astro";
import PluginCard from "../../components/PluginCard.astro";
import { buildDemoPost } from "../../data/demoPost";
import { resolvePlugin, resolvePlugins } from "../../lib/content";
import Base from "../../layouts/Base.astro";

const { slug } = Astro.params;
const plugin = await resolvePlugin(slug!);
if (!plugin) {
  return Astro.redirect("/plugins");
}
const allPlugins = await resolvePlugins();

function eyebrowText(p: typeof plugin) {
  if (!p) return "";
  if (p.slug === "engage") return "The engagement bundle";
  if (p.slug === "autobuild") return "Pure infrastructure";
  if (p.wordpressEquivalent) return `The EmDash alternative to ${p.wordpressEquivalent}`;
  return "Only on EmDash";
}

const eyebrow = eyebrowText(plugin);

// Fixture post for live demos with a real share message and URL per plugin.
const demoPost = buildDemoPost({
  id: `demo-${plugin!.slug}`,
  slug: "the-plugdash-launch",
  title: `Shipping with @plugdash/${plugin!.name}`,
  url: `https://plugdash.dev/plugins/${plugin!.slug}`,
  message: `${plugin!.tagline} - @plugdash/${plugin!.name}`,
});

const relatedPlugins = plugin!.pairs
  .map((name) => allPlugins.find((p) => p.slug === name))
  .filter(Boolean) as typeof allPlugins;

const p = plugin!;
const navPlugins = allPlugins;

const pageToc = [
  { id: "overview", text: "Overview" },
  { id: "demo", text: "Demo" },
  { id: "setup", text: "Setup" },
  { id: "customise", text: "Customise" },
  ...(relatedPlugins.length > 0 ? [{ id: "pairs", text: "Pairs well with" }] : []),
];

// A post-shaped object for this page so the plugin components we ship
// read from it the same way they read from any EmDash post.
const pageUrl = `https://plugdash.dev/plugins/${p.slug}`;
const pagePost = buildDemoPost({
  id: `plugin-page-${p.slug}`,
  slug: p.slug,
  title: `${p.name} - EmDash plugin - plugdash`,
  url: pageUrl,
  message: `${p.tagline} - @plugdash/${p.name}`,
  heartCount: 0,
});
pagePost.data.metadata.wordCount = 320;
pagePost.data.metadata.readingTimeMinutes = 2;
pagePost.data.metadata.shortlink = { url: pageUrl };
---

<Base
  title={`${p.name} - EmDash plugin - plugdash`}
  description={`${p.tagline}${p.wordpressEquivalent ? ` The EmDash alternative to ${p.wordpressEquivalent}.` : ` Available for EmDash via ${p.npmPackage}.`}`}
>
  <article class="plugin-page">
    <div class="plugin-layout container">
      <nav class="plugin-nav" aria-label="Plugins">
        <div class="plugin-nav-group">
          <div class="plugin-nav-label">Plugins</div>
          <ul>
            {navPlugins.map((pl) => (
              <li>
                <a
                  href={`/plugins/${pl.slug}`}
                  aria-current={pl.slug === p.slug ? "page" : undefined}
                >
                  {pl.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>

      <div class="plugin-body">
        <a href="/plugins" class="breadcrumb-pkg" aria-label="Back to plugins">
          {p.npmPackage}
        </a>

        <header class="plugin-header" id="overview">
          <p class="eyebrow">{eyebrow}</p>
          <h1 class="plugin-headline">{p.headline}</h1>
          <div class="plugin-meta">
            <ReadingTime post={pagePost} variant="inline" showWords />
            <span class="meta-sep" aria-hidden="true">•</span>
            <ShareButtons post={pagePost} variant="circle" size="sm" />
          </div>
          <p class="plugin-sub">{p.sub}</p>
          <div class="install-strip">
            <InstallCommand command={p.installCommand} />
            <span class="meta-sep" aria-hidden="true">•</span>
            <span class="status-badge" data-status={p.status}>{p.status}</span>
            <span class="meta-sep" aria-hidden="true">•</span>
            <a href={p.githubUrl} class="gh-link" rel="noopener">GitHub</a>
          </div>
        </header>

        <section class="demo-band" id="demo">
      <div class="demo-content">
        {p.slug === "readtime" && (
          <div class="demo-variants">
            <ReadingTime post={demoPost} variant="badge" />
            <ReadingTime post={demoPost} variant="pill" />
            <ReadingTime post={demoPost} variant="inline" />
            <ReadingTime post={demoPost} variant="minimal" />
          </div>
        )}
        {p.slug === "callout" && (
          <div class="demo-callouts">
            <Callout
              variant="info"
              title="Info"
              body="Background context readers might want but don't strictly need."
            />
            <Callout
              variant="tip"
              title="Tip"
              body="The non-obvious thing that makes the task easier."
            />
            <Callout
              variant="warning"
              title="Warning"
              body="Something that will bite them if they skip it."
            />
            <Callout
              variant="danger"
              title="Danger"
              body="Something that will break things if they get it wrong."
            />
          </div>
        )}
        {p.slug === "sharepost" && (
          <div class="demo-row">
            <ShareButtons post={demoPost} variant="circle" />
            <span class="demo-label">circle</span>
            <ShareButtons post={demoPost} variant="pill" />
            <span class="demo-label">pill</span>
          </div>
        )}
        {p.slug === "heartpost" && (
          <div class="demo-row">
            <HeartButton post={demoPost} />
            <span class="demo-label">one click, one count, no account</span>
          </div>
        )}
        {p.slug === "shortlink" && (
          <div class="demo-row">
            <CopyLink post={demoPost} variant="circle" />
            <CopyLink post={demoPost} variant="pill" />
            <CopyLink post={demoPost} variant="inline" />
          </div>
        )}
        {p.slug === "tocgen" && (
          <div class="demo-toc">
            <TableOfContents post={demoPost} />
          </div>
        )}
        {p.slug === "engage" && (
          <div class="demo-engage">
            <EngagementBar post={demoPost} attribution />
          </div>
        )}
        {p.slug === "autobuild" && (
          <div class="demo-sequence">
            <pre><code>{p.configExample}</code></pre>
            <div class="sequence">
              <span class="seq-step">publish in admin</span>
              <span class="seq-arrow">-&gt;</span>
              <span class="seq-step">hook fires</span>
              <span class="seq-arrow">-&gt;</span>
              <span class="seq-step">deploy kicks off</span>
              <span class="seq-arrow">-&gt;</span>
              <span class="seq-step">live</span>
            </div>
          </div>
        )}
        <p class="demo-caption">
          {p.slug === "autobuild" ? "No UI. Pure infrastructure." : "This is the default. No configuration."}
        </p>
      </div>
    </section>

        <section class="setup" id="setup">
      <h2>Setup</h2>
      <ol class="setup-steps">
        <li>
          <h3>Install and register</h3>
          <pre><code>{p.installCommand}</code></pre>
          {p.configExample && <pre><code>{p.configExample}</code></pre>}
        </li>
        {p.componentImport && (
          <li>
            <h3>Add to your layout</h3>
            <pre><code>{`${p.componentImport}\n\n${p.componentUsage}`}</code></pre>
          </li>
        )}
      </ol>
      <p class="setup-note">{p.setupNote}</p>
    </section>

        <details class="customise" id="customise">
      <summary>
        <h2>It looks right. But it's yours to change.</h2>
      </summary>
      <div class="customise-body">
        {p.slug === "autobuild" ? (
          <>
            <h3>AutobuildConfig</h3>
            <table class="prop-table">
              <thead><tr><th>option</th><th>type</th><th>default</th><th>description</th></tr></thead>
              <tbody>
                {p.props?.map((prop) => (
                  <tr>
                    <td><code>{prop.name}</code></td>
                    <td><code>{prop.type}</code></td>
                    <td>{prop.default ? <code>{prop.default}</code> : ""}</td>
                    <td>{prop.description}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </>
        ) : (
          <>
            {p.props && p.props.length > 0 && (
              <>
                <h3>Props</h3>
                <table class="prop-table">
                  <thead><tr><th>prop</th><th>type</th><th>default</th><th>description</th></tr></thead>
                  <tbody>
                    {p.props.map((prop) => (
                      <tr>
                        <td><code>{prop.name}</code></td>
                        <td><code>{prop.type}</code></td>
                        <td>{prop.default ? <code>{prop.default}</code> : ""}</td>
                        <td>{prop.description}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </>
            )}
            {p.cssTokens && p.cssTokens.length > 0 && (
              <>
                <h3>CSS custom properties</h3>
                <table class="prop-table">
                  <thead><tr><th>token</th><th>description</th></tr></thead>
                  <tbody>
                    {p.cssTokens.map((t) => (
                      <tr>
                        <td><code>{t.name}</code></td>
                        <td>{t.description}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </>
            )}
            <p class="customise-note">
              Components are intentionally simple. Copy <code>src/{p.companionComponent}</code>
              into your theme and modify freely - no upstream coupling.
            </p>
          </>
        )}
      </div>
    </details>

        {relatedPlugins.length > 0 && (
          <section class="pairs" id="pairs">
        <h2>Pairs well with</h2>
        {p.pairsNote && <p class="pairs-note">{p.pairsNote}</p>}
        <div class="plugin-grid">
          {relatedPlugins.map((r) => (
            <PluginCard
              name={r.name}
              tagline={r.tagline}
              status={r.status}
              installCommand={r.installCommand}
              slug={r.slug}
            />
          ))}
        </div>
          </section>
        )}

        <footer class="plugin-footer">
          <EngagementBar post={pagePost} />
          <a href="https://plugdash.dev" class="plugin-attribution" rel="noopener">
            built with plugdash
          </a>
        </footer>
      </div>

      <aside class="plugin-toc" aria-label="On this page">
        <div class="plugin-toc-label">On this page</div>
        <ul>
          {pageToc.map((t) => (
            <li><a href={`#${t.id}`}>{t.text}</a></li>
          ))}
        </ul>
      </aside>
    </div>
  </article>
</Base>

<style>
  .plugin-page {
    padding: 2rem 0 4rem;
  }
  .plugin-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 1024px) {
    .plugin-layout {
      grid-template-columns: 200px minmax(0, 1fr) 200px;
      gap: 2.5rem;
    }
  }
  .plugin-body {
    min-width: 0;
  }

  .plugin-nav {
    display: none;
  }
  @media (min-width: 1024px) {
    .plugin-nav {
      display: block;
      position: sticky;
      top: 1rem;
      align-self: start;
      max-height: calc(100vh - 2rem);
      overflow-y: auto;
    }
  }
  .plugin-nav-group {
    margin-bottom: 1.25rem;
  }
  .plugin-nav-label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .plugin-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .plugin-nav li {
    margin: 0;
  }
  .plugin-nav a {
    display: block;
    padding: 0.3rem 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .plugin-nav a:hover {
    color: var(--text);
  }
  .plugin-nav a[aria-current="page"] {
    color: var(--accent);
  }

  .plugin-toc {
    display: none;
  }
  @media (min-width: 1024px) {
    .plugin-toc {
      display: block;
      position: sticky;
      top: 1rem;
      align-self: start;
    }
  }
  .plugin-toc-label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .plugin-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .plugin-toc li {
    margin: 0;
  }
  .plugin-toc a {
    display: block;
    padding: 0.3rem 0;
    color: var(--muted);
    font-size: 0.85rem;
  }
  .plugin-toc a:hover {
    color: var(--text);
  }

  .breadcrumb-pkg {
    display: inline-block;
    font-family: var(--plugdash-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .breadcrumb-pkg:hover {
    color: var(--text);
  }
  .plugin-header {
    margin-bottom: 2.5rem;
  }
  .plugin-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0.75rem 0 1.25rem;
    color: var(--muted);
    font-size: 0.875rem;
  }
  .meta-sep {
    color: var(--muted);
    opacity: 0.5;
    user-select: none;
  }
  .plugin-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .plugin-attribution {
    font-size: 0.8rem;
    color: var(--muted);
  }
  .plugin-attribution:hover {
    color: var(--text);
  }
  .plugin-header .eyebrow {
    margin-bottom: 0.75rem;
  }
  .plugin-headline {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .plugin-sub {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .install-strip {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .gh-link {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .gh-link:hover {
    color: var(--text);
  }

  .demo-band {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2.5rem 1.5rem;
    margin: 0 0 2.5rem;
    color: var(--text);
  }
  .demo-band .demo-content {
    text-align: center;
  }
  .demo-variants,
  .demo-row,
  .demo-engage {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
  }
  .demo-callouts {
    display: grid;
    gap: 1rem;
    text-align: left;
    max-width: 40rem;
    margin: 0 auto;
  }
  .demo-label {
    color: var(--muted);
    font-size: 0.8rem;
  }
  .demo-toc {
    max-width: 30rem;
    margin: 0 auto;
    text-align: left;
  }
  .demo-sequence {
    max-width: 40rem;
    margin: 0 auto;
    text-align: left;
  }
  .demo-sequence pre {
    background: var(--bg);
    border-color: var(--border);
    color: var(--text);
    margin-bottom: 1.5rem;
  }
  .sequence {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--plugdash-font-mono);
    font-size: 0.85rem;
    color: var(--text);
  }
  .seq-step {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.3rem 0.6rem;
  }
  .seq-arrow {
    color: var(--muted);
  }
  .demo-caption {
    margin-top: 1.5rem;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .setup {
    padding: 2rem 0;
  }
  .setup h2 {
    margin-bottom: 1.25rem;
  }
  .setup-steps {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .setup-steps > li {
    margin-bottom: 1.75rem;
  }
  .setup-steps h3 {
    font-size: 1rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
  .setup-steps pre {
    margin-block: 0.5rem;
  }
  .setup-note {
    color: var(--muted);
    font-size: 0.95rem;
    margin-top: 1rem;
  }

  .customise {
    padding: 1rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    margin: 1rem 0 2rem;
    background: var(--surface);
  }
  .customise summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  /* list-style: none on summary hides the marker in modern Chrome/Safari */
  .customise summary::before {
    content: "+";
    color: var(--muted);
    font-family: var(--plugdash-font-mono);
    font-size: 1.25rem;
    line-height: 1;
    width: 1rem;
  }
  .customise[open] summary::before {
    content: "-";
  }
  .customise summary h2 {
    display: inline;
    font-size: 1.1rem;
    font-weight: 500;
    margin: 0;
  }
  .customise-body {
    margin-top: 1.25rem;
  }
  .customise-body h3 {
    font-size: 0.95rem;
    color: var(--muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .prop-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .prop-table th,
  .prop-table td {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .prop-table th {
    color: var(--muted);
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .customise-note {
    color: var(--muted);
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  .pairs {
    padding: 2rem 0 0;
  }
  .pairs h2 {
    margin-bottom: 0.5rem;
  }
  .pairs-note {
    color: var(--muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    max-width: 42rem;
  }
  .plugin-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) {
    .plugin-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
