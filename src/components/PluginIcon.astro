---
import Timer from "phosphor-astro/Timer.astro";
import ListNumbers from "phosphor-astro/ListNumbers.astro";
import ShareNetwork from "phosphor-astro/ShareNetwork.astro";
import Heart from "phosphor-astro/Heart.astro";
import LinkSimple from "phosphor-astro/LinkSimple.astro";
import MegaphoneSimple from "phosphor-astro/MegaphoneSimple.astro";
import RocketLaunch from "phosphor-astro/RocketLaunch.astro";
import HandHeart from "phosphor-astro/HandHeart.astro";

interface Props {
  slug: string;
  size?: number;
  class?: string;
}

const { slug, size = 24, class: className } = Astro.props;
---

{slug === "readtime" && <Timer width={size} height={size} class={className} />}
{slug === "tocgen" && <ListNumbers width={size} height={size} class={className} />}
{slug === "sharepost" && <ShareNetwork width={size} height={size} class={className} />}
{slug === "heartpost" && <Heart width={size} height={size} class={className} />}
{slug === "shortlink" && <LinkSimple width={size} height={size} class={className} />}
{slug === "callout" && <MegaphoneSimple width={size} height={size} class={className} />}
{slug === "autobuild" && <RocketLaunch width={size} height={size} class={className} />}
{slug === "engage" && <HandHeart width={size} height={size} class={className} />}
