---
interface Props {
  command: string;
  class?: string;
}

const { command, class: className = "" } = Astro.props;
const id = `install-${Math.random().toString(36).slice(2, 9)}`;
---

<div class={`install-command ${className}`} data-install>
  <code id={id}>{command}</code>
  <button
    type="button"
    class="install-copy"
    data-copy-target={id}
    data-copy-value={command}
    aria-label={`Copy: ${command}`}
    title="Copy to clipboard"
  >
    <svg class="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
  </button>
</div>

<style>
  .install-command {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    overflow: hidden;
    font-family: var(--plugdash-font-mono);
    font-size: 0.875rem;
    max-width: 100%;
  }
  .install-command code {
    padding: 0.55rem 0.85rem;
    background: none;
    border: none;
    color: var(--text-strong);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
    display: inline-flex;
    align-items: center;
  }
  .install-copy {
    border: none;
    border-left: 1px solid var(--border);
    background: none;
    color: var(--muted);
    padding: 0 0.7rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color var(--plugdash-transition), background var(--plugdash-transition);
  }
  .install-copy:hover {
    color: var(--text-strong);
    background: var(--bg);
  }
  .install-copy svg {
    width: 14px;
    height: 14px;
  }
  .install-copy .icon-check {
    display: none;
    color: var(--accent);
  }
  .install-copy[data-copied="true"] .icon-copy {
    display: none;
  }
  .install-copy[data-copied="true"] .icon-check {
    display: block;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".install-copy").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const value = btn.getAttribute("data-copy-value") ?? "";
      try {
        await navigator.clipboard.writeText(value);
        btn.setAttribute("data-copied", "true");
        setTimeout(() => btn.removeAttribute("data-copied"), 2000);
      } catch (e) {
        // clipboard may be unavailable - ignore silently
      }
    });
  });
</script>
